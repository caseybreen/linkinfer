    rlang,
    stats,
    cli
Suggests:
    autumn,
    ranger,
    ggplot2,
    knitr,
    rmarkdown,
    testthat (>= 3.0.0)
VignetteBuilder: knitr
Remotes:
    aaronrudkin/autumn
Config/testthat/edition: 3
Depends: 
    R (>= 3.5)
LazyData: true
